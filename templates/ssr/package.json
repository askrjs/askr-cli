{
  "name": "{{appName}}",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development node --loader tsx ./server.ts",
    "build": "vp build && vp build --ssr src/entry-server.tsx && tsc -p tsconfig.server.json",
    "preview": "cross-env NODE_ENV=production node dist/server/server.js",
    "test": "npx vite-plus test run",
    "type-check": "tsc --noEmit",
    "lint": "npx vite-plus lint src server.ts tests",
    "lint:fix": "npx vite-plus lint --fix src server.ts tests",
    "fmt": "npx vite-plus fmt \"src/**/*.{ts,tsx,css}\" \"server.ts\" \"tests/**/*.{ts,tsx}\" \"*.md\""
  },
  "dependencies": {
    "@askrjs/askr": "0.1.0",
    "@askrjs/ui": "0.1.0",
    "@askrjs/themes": "0.1.0",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@askrjs/vite": "0.1.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "cross-env": "^10.1.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite-plus": "^0.1.19"
  }
}

