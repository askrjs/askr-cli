{
  "name": "{{appName}}",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development node --loader tsx ./server.ts",
    "build": "vp build && vp build --ssr src/entry-server.tsx && tsc -p tsconfig.server.json",
    "preview": "cross-env NODE_ENV=production node dist/server/server.js",
    "test": "vp test run",
    "type-check": "tsc --noEmit",
    "lint": "vp lint src server.ts tests",
    "lint:fix": "vp lint --fix src server.ts tests",
    "fmt": "vp fmt \"src/**/*.{ts,tsx,css}\" \"server.ts\" \"tests/**/*.{ts,tsx}\" \"*.md\""
  },
  "dependencies": {
    "@askrjs/askr": "0.0.1",
    "@askrjs/askr-ui": "0.0.1",
    "@askrjs/askr-themes": "0.0.1",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@askrjs/askr-vite": "0.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "cross-env": "^10.1.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite-plus": "latest"
  }
}
