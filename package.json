{
  "name": "@askrjs/askr-cli",
  "version": "0.0.1",
  "description": "Unified CLI for the askr platform",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/askrjs/askr-cli.git"
  },
  "homepage": "https://github.com/askrjs/askr-cli#readme",
  "bugs": {
    "url": "https://github.com/askrjs/askr-cli/issues"
  },
  "author": {
    "name": "askrjs",
    "url": "https://github.com/askrjs"
  },
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "askr-cli": "./src/bin/cli.js",
    "askr-ssg": "./src/bin/ssg.js",
    "askr-create": "./src/bin/create.js"
  },
  "files": [
    "src",
    "templates"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node --check ./src/bin/cli.js && node --check ./src/bin/create.js && node --check ./src/bin/ssg.js",
    "test": "node --test ./tests/*.test.js",
    "fmt": "vp fmt .",
    "lint": "vp fmt --check ."
  },
  "dependencies": {
    "@askrjs/askr": "0.0.1"
  },
  "devDependencies": {
    "vite-plus": "latest"
  }
}
